# Copy this file to /opt/windmill/.env on the VPC host and replace values.
# Keep the real .env off git and chmod it to 600.

POSTGRES_PASSWORD=replace-with-a-random-password
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@db/windmill?sslmode=disable
SUPERADMIN_SECRET=replace-with-a-random-virtual-superadmin-token

# Pin these to tested Windmill releases before production. main is acceptable for this dev worker.
WM_IMAGE=ghcr.io/windmill-labs/windmill:main
WM_WORKER_IMAGE=compute-bazaar-windmill-worker:2026-06-17

# The compose template binds the UI to 127.0.0.1:8081 on the EC2 host.
# Reach it from your laptop with:
# ssh -i .secrets/compute-bazaar-automq-runtime.pem -L 8081:127.0.0.1:8081 ec2-user@51.44.12.211
BASE_URL=:80
ADDRESS=0.0.0.0

AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3
SILENCE_HEALTH_LOGS=true
