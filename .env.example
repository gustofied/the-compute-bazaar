AWS_PROFILE=compute-bazaar
AWS_REGION=YOUR_AWS_REGION
COMPUTE_BAZAAR_RAW_ROOT=s3://YOUR_BUCKET/raw
COMPUTE_BAZAAR_LAKE_ROOT=s3://YOUR_BUCKET/lake
COMPUTE_BAZAAR_DASHBOARD_OUTPUT_ROOT=s3://YOUR_BUCKET/dashboard/compute-bazaar
# Optional. Dashboard source defaults to auto:
# - if COMPUTE_BAZAAR_DASHBOARD_OUTPUT_ROOT is s3://..., use that
# - otherwise infer s3://YOUR_BUCKET/dashboard/compute-bazaar from COMPUTE_BAZAAR_LAKE_ROOT=s3://YOUR_BUCKET/lake
# - set COMPUTE_BAZAAR_DASHBOARD_SOURCE=local to force data/dashboard/compute-bazaar
COMPUTE_BAZAAR_DASHBOARD_SOURCE=auto
# COMPUTE_BAZAAR_DASHBOARD_S3_PREFIX=s3://YOUR_BUCKET/dashboard/compute-bazaar
COMPUTE_BAZAAR_ADAM_SIOUD_PORT=8777

# Secrets / service-specific connection settings.
VAST_API_KEY=
LIUM_API_KEY=
COMPUTE_BAZAAR_KAFKA_BOOTSTRAP_SERVERS=
COMPUTE_BAZAAR_KAFKA_SECURITY_PROTOCOL=
COMPUTE_BAZAAR_KAFKA_SASL_MECHANISM=
COMPUTE_BAZAAR_KAFKA_USERNAME=
COMPUTE_BAZAAR_KAFKA_PASSWORD=
AUTOMQ_SSL_CA_LOCATION=
AUTOMQ_SSL_CERTIFICATE_LOCATION=
AUTOMQ_SSL_KEY_LOCATION=
